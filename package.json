    "react-dom": "^19.2.7",
    "word-list": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "daisyui": "^5.6.18",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
